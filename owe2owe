<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Peoples Bank • Twin Edition</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>

    <div class="container">
        <header>
            <h1>Peoples Bank <span>Twin</span></h1>
            <p class="subtitle" id="view-subtitle">You are the Lender.</p>

            <div class="twin-switch">
                <div class="switch-bg" id="switch-bg"></div>
                <button class="switch-btn active" onclick="setMode('lender')" id="btn-lender">Lender View</button>
                <button class="switch-btn" onclick="setMode('borrower')" id="btn-borrower">Borrower View</button>
            </div>
        </header>

        <!-- Balance Dashboard -->
        <div class="balance-container">
            <div class="balance-label">Net Balance</div>
            <div class="balance-val" id="balance-display">£0.00</div>
        </div>

        <!-- Tab Navigation -->
        <div class="tab-bar">
            <button class="tab-btn active" data-tab="records" onclick="switchTab('records')">Records</button>
            <button class="tab-btn" data-tab="investments" onclick="switchTab('investments')">Investments</button>
            <button class="tab-btn" data-tab="instalments" onclick="switchTab('instalments')">Instalments</button>
            <button class="tab-btn" data-tab="import" onclick="switchTab('import')">Import</button>
            <button class="tab-btn" data-tab="settings" onclick="switchTab('settings')">Settings</button>
        </div>

        <!-- ========== TAB: Records ========== -->
        <div class="tab-content active" id="tab-records">
            <div class="panel" style="padding:18px;">
                <h2 id="form-title" style="font-size:1.1rem; margin-bottom:12px;">New Loan / Investment</h2>
                <form onsubmit="handleAdd(event)">
                    <!-- Row 1: Amount + Currency + Name -->
                    <div style="display:grid; grid-template-columns:1fr 60px 2fr; gap:8px;">
                        <div>
                            <label class="field-label">Amount *</label>
                            <input type="number" id="p-amount" step="0.01" placeholder="0.00" required style="margin-bottom:6px;">
                        </div>
                        <div>
                            <label class="field-label">Cur</label>
                            <input type="text" id="p-curr" value="£" style="margin-bottom:6px; text-align:center;">
                        </div>
                        <div>
                            <label class="field-label">Person</label>
                            <input type="text" id="p-name" placeholder="Other party" list="people-list" style="margin-bottom:6px;">
                            <datalist id="people-list"></datalist>
                        </div>
                    </div>

                    <!-- Row 2: Date + Reason -->
                    <div style="display:grid; grid-template-columns:1fr 2fr; gap:8px;">
                        <div>
                            <label class="field-label">Date</label>
                            <input type="date" id="p-date" style="margin-bottom:6px;">
                        </div>
                        <div>
                            <label class="field-label">Reason</label>
                            <input type="text" id="p-reason" placeholder="What for?" style="margin-bottom:6px;">
                        </div>
                    </div>

                    <!-- Proof: compact row -->
                    <div class="proof-row" style="margin-top:2px; margin-bottom:6px;">
                        <input type="file" id="p-proof" accept="image/*" style="margin-bottom:0;">
                        <button type="button" class="btn-camera" onclick="takeProofPhoto()" title="Camera">📸</button>
                    </div>
                    <div id="camera-status"></div>

                    <!-- Investment Toggle (Lender mode only) -->
                    <div class="toggle-row" id="invest-toggle" style="padding:8px 12px; margin-bottom:8px;" onclick="var cb = document.getElementById('p-invest'); cb.checked = !cb.checked; toggleInvestFields(cb.checked);">
                        <input type="checkbox" id="p-invest" onclick="event.stopPropagation(); toggleInvestFields(this.checked);">
                        <span class="toggle-label" style="font-size:0.85rem;">Investment</span>
                        <span class="toggle-hint">No repayment — earn interest</span>
                    </div>

                    <!-- Investment fields (hidden by default) -->
                    <div class="invest-fields" id="invest-fields">
                        <div class="form-grid-3">
                            <div>
                                <label class="field-label" style="color:var(--invest);">Rate (%)</label>
                                <input type="number" id="p-interest-rate" step="0.1" min="0" value="0" placeholder="5">
                            </div>
                            <div>
                                <label class="field-label" style="color:var(--invest);">Type</label>
                                <select id="p-interest-type">
                                    <option value="none">None</option>
                                    <option value="simple">Simple</option>
                                    <option value="compound">Compound</option>
                                </select>
                            </div>
                            <div>
                                <label class="field-label" style="color:var(--invest);">Importance</label>
                                <select id="p-importance">
                                    <option value="low">Low</option>
                                    <option value="normal" selected>Normal</option>
                                    <option value="high">High</option>
                                    <option value="critical">Critical</option>
                                </select>
                            </div>
                        </div>
                        <div style="display:grid; grid-template-columns:1fr 2fr; gap:8px;">
                            <div>
                                <label class="field-label" style="color:var(--invest);">Duration</label>
                                <input type="text" id="p-contract-duration" placeholder="e.g. 2 years">
                            </div>
                            <div>
                                <label class="field-label" style="color:var(--invest);">Terms</label>
                                <input type="text" id="p-contract-note" placeholder="Contract notes...">
                            </div>
                        </div>
                    </div>

                    <!-- Contact & Account (collapsible) -->
                    <div class="details-toggle" style="padding:6px 12px; margin-bottom:6px;" onclick="document.getElementById('contact-fields').classList.toggle('visible');">
                        + Contact &amp; Account <span style="margin-left:auto; font-size:0.7rem;">(optional)</span>
                    </div>
                    <div class="details-content" id="contact-fields">
                        <div class="form-grid-3">
                            <div>
                                <label class="field-label">Phone</label>
                                <input type="tel" id="p-phone" placeholder="07123456789">
                            </div>
                            <div>
                                <label class="field-label">Email</label>
                                <input type="email" id="p-contact-email" placeholder="them@email.com">
                            </div>
                            <div>
                                <label class="field-label">Account</label>
                                <input type="text" id="p-account" placeholder="12-34-56 / 12345678">
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn-primary" id="btn-submit" style="margin-top:4px;">Record Transaction</button>
                </form>
            </div>

            <div class="panel" style="padding:18px;">
                <h2 style="font-size:1.1rem;">Records</h2>
                <div id="list"></div>
            </div>
        </div>

        <!-- ========== TAB: Investments ========== -->
        <div class="tab-content" id="tab-investments">
            <div class="panel">
                <h2>Investment Portfolio <small style="font-size:0.8rem; font-weight:normal; color:var(--invest);">Interest accrues over time</small></h2>
                <div id="investments-list"></div>
            </div>
        </div>

        <!-- ========== TAB: Instalments ========== -->
        <div class="tab-content" id="tab-instalments">
            <div id="instalments-list"></div>
        </div>

        <!-- ========== TAB: Import ========== -->
        <div class="tab-content" id="tab-import">
            <div class="panel">
                <h2>Smart Import <small style="font-size:0.8rem;font-weight:normal;">(Monzo CSV)</small></h2>
                <div class="csv-area" onclick="document.getElementById('csv-file').click()">
                    <div style="font-size:2rem;">📂</div>
                    <div>Click to Upload Monzo Statement</div>
                    <div class="csv-hint">Matches outgoing payments to your "Borrower" debts automatically.</div>
                </div>
                <input type="file" id="csv-file" accept=".csv" style="display:none" onchange="handleCSV(this)">
            </div>
        </div>

        <!-- ========== TAB: Settings ========== -->
        <div class="tab-content" id="tab-settings">
            <div class="panel">
                <h2>Settings</h2>
                <label class="field-label">Your Email (for export)</label>
                <div style="display:flex; gap:10px; margin-bottom:20px;">
                    <input type="email" id="my-email" placeholder="you@example.com" style="margin-bottom:0;">
                    <button onclick="saveEmail()" class="btn-sm" style="white-space:nowrap;">Save</button>
                </div>

                <h2>Device Sync <small style="font-size:0.8rem; font-weight:normal; color:var(--muted);">No internet needed</small></h2>
                <p style="font-size:0.85rem; color:var(--muted); margin-top:0;">
                    Both parties fill in the deal on their own device, then export the same file.
                    Import on the other device to merge — matching records, no data touches the web.
                </p>
                <div class="sync-row">
                    <button class="sync-btn" onclick="exportData()">
                        <span class="sync-icon">📤</span>
                        <span class="sync-label">Export All Data</span>
                        <span class="sync-hint">Save as .json file</span>
                    </button>
                    <label class="sync-btn" for="import-file" style="margin:0;">
                        <span class="sync-icon">📥</span>
                        <span class="sync-label">Import Data</span>
                        <span class="sync-hint">Merge from .json file</span>
                    </label>
                    <input type="file" id="import-file" accept=".json" style="display:none" onchange="importData(this)">
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for CSV Matches -->
    <dialog id="match-modal">
        <div class="modal-header">
            <span>Potential Matches Found</span>
            <span onclick="document.getElementById('match-modal').close()" style="cursor:pointer;">✕</span>
        </div>
        <div class="modal-body" id="match-list"></div>
    </dialog>

    <!-- Camera Modal -->
    <dialog id="camera-modal">
        <div class="modal-header">
            <span>Take Proof Photo</span>
            <span onclick="cancelCamera()" style="cursor:pointer;">✕</span>
        </div>
        <div class="modal-body" style="padding:0; overflow:hidden;">
            <video id="camera-video" class="camera-preview" autoplay playsinline></video>
            <canvas id="camera-canvas" style="display:none;"></canvas>
        </div>
        <div class="camera-actions">
            <button class="btn-snap" onclick="snapPhoto()">📸 Snap</button>
            <button class="btn-cancel-cam" onclick="cancelCamera()">Cancel</button>
        </div>
    </dialog>

    <!-- Contract Modal (fullscreen-ish) -->
    <dialog id="contract-modal" style="max-width:700px; width:95%;">
        <div class="modal-header">
            <span>Contract</span>
            <span onclick="closeContractModal()" style="cursor:pointer;">✕</span>
        </div>
        <div class="modal-body" style="max-height:75vh;">
            <!-- Contract preview image -->
            <div id="contract-preview"></div>

            <!-- Signature zone -->
            <div id="contract-sig-section" style="margin-top:14px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px;">
                    <span style="font-size:0.85rem; color:var(--muted); font-family:monospace;">SIGN BELOW</span>
                    <button class="btn-sm" onclick="clearSignature()" style="font-size:0.75rem;">Clear</button>
                </div>
                <div style="border:1px solid var(--border); border-radius:8px; overflow:hidden;">
                    <canvas id="sig-canvas" style="display:block; width:100%; touch-action:none;"></canvas>
                </div>
            </div>

            <!-- Confirm button -->
            <button id="contract-confirm-btn" class="btn-primary" onclick="confirmContract()" style="margin-top:14px;">
                Confirm &amp; Save
            </button>

            <!-- Sharing options (shown after confirm) -->
            <div id="contract-sharing" style="display:none; margin-top:16px;">
                <div style="font-size:0.85rem; color:var(--muted); margin-bottom:10px; font-family:monospace; text-align:center;">
                    DEAL SAVED — SHARE IT
                </div>
                <div class="sync-row" style="flex-wrap:wrap;">
                    <button class="sync-btn" onclick="shareDownloadPNG()">
                        <span class="sync-icon">🖼</span>
                        <span class="sync-label">PNG</span>
                        <span class="sync-hint">Contract image</span>
                    </button>
                    <button class="sync-btn" onclick="shareDownloadJSON()">
                        <span class="sync-icon">📄</span>
                        <span class="sync-label">JSON</span>
                        <span class="sync-hint">Transaction data</span>
                    </button>
                    <button class="sync-btn" onclick="shareEmail()">
                        <span class="sync-icon">✉️</span>
                        <span class="sync-label">Email</span>
                        <span class="sync-hint">Draft with details</span>
                    </button>
                </div>
                <!-- QR Code -->
                <div style="text-align:center; margin-top:14px;">
                    <div style="font-size:0.8rem; color:var(--muted); margin-bottom:8px; font-family:monospace;">SCAN TO IMPORT ON OTHER DEVICE</div>
                    <div id="contract-qr" style="display:inline-block;"></div>
                </div>
                <button class="btn-primary" onclick="closeContractModal()" style="margin-top:14px; background:var(--panel); color:var(--text); border:1px solid var(--border);">
                    Done
                </button>
            </div>
        </div>
    </dialog>

    <!-- QR Code library (no npm, no build, just a CDN script) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

    <script src="app.js"></script>
    <script src="investments.js"></script>
    <script src="instalments.js"></script>
    <script src="csv.js"></script>
    <script src="sync.js"></script>
    <script src="contract.js"></script>
    <script src="signature.js"></script>
    <script src="sharing.js"></script>

</body>
</html>
